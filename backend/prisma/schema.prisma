generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model Professor{
  id        String   @id @default(cuid())
  clerkId   String   @unique
  alunos    Alunos[]
}

model Alunos{
  id          String   @id @default(cuid())
  nome        String
  turma       String
  professorId String
  email       String
  notas       String
  foto        String?
  updatedAt   DateTime @updatedAt
  presenca    Presenca[]
  professor   Professor @relation(fields: [professorId], references: [id])

}

model Presenca{
  id        String   @id @default(cuid())
  alunoId   String
  data      DateTime @default(now())
  presente  Boolean
  justifica Boolean
  aluno     Alunos @relation(fields: [alunoId], references: [id])
}

//professorId deve ser irrelevante