generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id      String   @id @default(cuid())
  clerkId String   @unique
  alunos  Alunos[]
}

model Alunos {
  id           String     @id @default(cuid())
  nome         String
  turma        String
  dataNasc     DateTime   @default(now())
  diretorTurma String     @default("N/A")
  professorId  String
  notas        String     @default("")
  foto         String?
  updatedAt    DateTime   @updatedAt
  presenca     Presenca[]
  professor    Professor  @relation(fields: [professorId], references: [id])

  MSAI MSAI[]
}

model MSAI {
  id      String @id @default(cuid())
  alunoId String
  msai    String @default("000000000000000") @db.Bit(15)
  aluno   Alunos @relation(fields: [alunoId], references: [id])
}

model Presenca {
  id        String   @id @default(cuid())
  alunoId   String
  data      DateTime @default(now())
  presente  Boolean
  justifica Boolean
  aluno     Alunos   @relation(fields: [alunoId], references: [id])
}

//professorId deve ser irrelevante
